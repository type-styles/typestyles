{
  "name": "@typestyles/benchmarks",
  "private": true,
  "version": "0.0.3",
  "type": "module",
  "scripts": {
    "bench": "node --expose-gc --import tsx run.ts",
    "bench:ci": "node --expose-gc --import tsx run.ts --ci",
    "bench:update": "node --expose-gc --import tsx run.ts --update-baseline"
  },
  "dependencies": {
    "typestyles": "workspace:*",
    "@vanilla-extract/css": "^1.20.1",
    "@vanilla-extract/recipes": "^0.5.7"
  },
  "devDependencies": {
    "@types/node": "^25.2.1",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0"
  }
}
