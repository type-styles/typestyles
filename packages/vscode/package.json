{
  "name": "@typestyles/vscode",
  "displayName": "TypeStyles",
  "description": "Hover CSS previews, token swatches, and go-to-definition for TypeStyles",
  "version": "0.1.0",
  "publisher": "typestyles",
  "license": "Apache-2.0",
  "type": "commonjs",
  "main": "./dist/extension.js",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Linters",
    "Programming Languages"
  ],
  "keywords": [
    "typestyles",
    "css-in-ts",
    "css",
    "typescript"
  ],
  "activationEvents": [
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onLanguage:javascript",
    "onLanguage:javascriptreact"
  ],
  "contributes": {
    "configuration": {
      "title": "TypeStyles",
      "properties": {
        "typestyles.previewMode": {
          "type": "string",
          "enum": [
            "semantic",
            "hashed",
            "compact"
          ],
          "default": "semantic",
          "description": "Class naming mode used for hover CSS previews when scopeId cannot be inferred from the file."
        },
        "typestyles.showCssPropertyDocs": {
          "type": "boolean",
          "default": true,
          "description": "Show short CSS property documentation when hovering style object keys."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs && node scripts/copy-assets.mjs",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "package": "vsce package --no-dependencies"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/type-styles/typestyles",
    "directory": "packages/vscode"
  },
  "dependencies": {
    "typescript": "^5.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.2",
    "vitest": "^3.0.0"
  },
  "files": [
    "dist",
    "icon.png",
    "README.md",
    "LICENSE"
  ]
}
