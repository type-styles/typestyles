{
  "name": "@typestyles/cli",
  "version": "0.2.0",
  "description": "TypeStyles command-line tools",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "typestyles": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "typestyles",
    "cli",
    "design-system",
    "css",
    "semver"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/type-styles/typestyles",
    "directory": "packages/cli"
  },
  "dependencies": {
    "fast-glob": "^3.3.3",
    "typescript": "^5.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.1",
    "eslint": "^9.39.2",
    "tsup": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
