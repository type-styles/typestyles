---
// @ts-nocheck
import { toc } from '../../styles';
import type { DocHeading } from '../../lib/docs';

interface Props {
  headings: DocHeading[];
  /** `id` for the visible section title; omit when `showTitle` is false. */
  labelledBy?: string;
  /** Mobile drawer already has a summary line; hide inner title when false. */
  showTitle?: boolean;
}

const { headings, labelledBy = 'docs-toc-title', showTitle = true } = Astro.props as Props;

const padForDepth = (depth: number) => Math.max(0, depth - 2) * 12;
---

<nav
  class={toc.nav}
  aria-labelledby={showTitle ? labelledBy : undefined}
  aria-label={showTitle ? undefined : 'Table of contents'}
  data-docs-toc-nav
>
  {showTitle ? <p id={labelledBy} class={toc.title}>On this page</p> : null}
  <ul class={toc.list}>
    {
      headings.map((h) => (
        <li class={toc.item} style={{ paddingLeft: `${padForDepth(h.depth)}px` }}>
          <a href={`#${h.id}`} class={toc.link} data-docs-toc-link>
            {h.text}
          </a>
        </li>
      ))
    }
  </ul>
</nav>
<script>
  // Keep TOC behavior colocated with the TOC component.
  // Astro dedupes this script when the nav appears twice (mobile + desktop); init every instance.
  const initialized = new WeakSet<HTMLElement>();

  const initDocsToc = (nav: HTMLElement) => {
    if (initialized.has(nav)) return;
    initialized.add(nav);

    const links = [...nav.querySelectorAll<HTMLAnchorElement>('[data-docs-toc-link]')];
    if (links.length === 0) return;

    const idFromLink = (a: HTMLAnchorElement) => decodeURIComponent(a.hash.replace(/^#/, ''));
    const headingEls = links
      .map((a) => document.getElementById(idFromLink(a)))
      .filter((el): el is HTMLElement => el != null);
    if (headingEls.length === 0) return;

    const clearCurrent = () => {
      for (const a of links) a.removeAttribute('aria-current');
    };
    const setCurrent = (id: string) => {
      clearCurrent();
      for (const a of links) {
        if (idFromLink(a) === id) a.setAttribute('aria-current', 'location');
      }
    };

    const visible = new Map<Element, number>();
    const observer = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) visible.set(e.target, e.intersectionRatio);
          else visible.delete(e.target);
        }
        if (visible.size === 0) return;

        let best: HTMLElement | null = null;
        let bestTop = Infinity;
        for (const el of headingEls) {
          if (!visible.has(el)) continue;
          const r = el.getBoundingClientRect();
          if (r.top >= 0 && r.top < bestTop) {
            bestTop = r.top;
            best = el;
          }
        }

        if (!best) {
          // Fallback: nearest heading above the viewport top threshold.
          let nearestAboveTop = -Infinity;
          for (const el of headingEls) {
            if (!visible.has(el)) continue;
            const r = el.getBoundingClientRect();
            if (r.top < 120 && r.top > nearestAboveTop) {
              nearestAboveTop = r.top;
              best = el;
            }
          }
        }

        if (!best) best = headingEls[0] ?? null;
        if (best?.id) setCurrent(best.id);
      },
      {
        root: null,
        rootMargin: '-64px 0px -55% 0px',
        threshold: [0, 0.25, 0.5, 0.75, 1],
      },
    );

    for (const h of headingEls) observer.observe(h);

    const onScrollEnd = () => {
      const fromTop = headingEls
        .map((el) => ({ el, top: el.getBoundingClientRect().top }))
        .filter(({ top }) => top <= 120)
        .sort((a, b) => b.top - a.top);
      const pick = fromTop[0]?.el ?? headingEls[0];
      if (pick?.id) setCurrent(pick.id);
    };

    let t: ReturnType<typeof setTimeout> | undefined;
    window.addEventListener(
      'scroll',
      () => {
        if (t) clearTimeout(t);
        t = setTimeout(onScrollEnd, 64);
      },
      { passive: true },
    );

    onScrollEnd();
  };

  const run = () => {
    document.querySelectorAll<HTMLElement>('[data-docs-toc-nav]').forEach(initDocsToc);
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', run, { once: true });
  } else {
    run();
  }
</script>
