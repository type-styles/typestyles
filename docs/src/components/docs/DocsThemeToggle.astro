---
// @ts-nocheck
type Props = {
  darkThemeClass: string;
};

const { darkThemeClass } = Astro.props;
---

<script define:vars={{ darkThemeClass }}>
  const root = document.documentElement;
  const sidebarThemeToggleElement = document.getElementById('theme-toggle-sidebar');
  const mobileThemeToggleElement = document.getElementById('theme-toggle-mobile');

  function setTheme(isDark) {
    if (isDark) {
      root.classList.add(darkThemeClass);
      localStorage.setItem('typestyles-theme', 'dark');
    } else {
      root.classList.remove(darkThemeClass);
      localStorage.setItem('typestyles-theme', 'light');
    }
  }

  function toggleTheme() {
    setTheme(!root.classList.contains(darkThemeClass));
  }

  sidebarThemeToggleElement?.addEventListener('click', toggleTheme);
  mobileThemeToggleElement?.addEventListener('click', toggleTheme);
</script>
