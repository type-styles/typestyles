---
// @ts-nocheck
type Props = {
  darkThemeClass: string;
  sidebarRootOpenClass: string;
  sidebarBackdropVisibleClass: string;
};

const { darkThemeClass, sidebarRootOpenClass, sidebarBackdropVisibleClass } = Astro.props;
---

<script
  define:vars={{
    darkThemeClass,
    sidebarRootOpenClass,
    sidebarBackdropVisibleClass,
  }}
>
  const root = document.documentElement;
  const sidebarElement = document.getElementById('docs-sidebar');
  const backdropElement = document.getElementById('sidebar-backdrop');
  const menuToggleElement = document.getElementById('mobile-menu-toggle');
  const menuIconElement = document.getElementById('mobile-menu-icon');
  const sidebarThemeToggleElement = document.getElementById('theme-toggle-sidebar');
  const mobileThemeToggleElement = document.getElementById('theme-toggle-mobile');

  let isOpen = false;

  function setTheme(isDark) {
    if (isDark) {
      root.classList.add(darkThemeClass);
      localStorage.setItem('typestyles-theme', 'dark');
    } else {
      root.classList.remove(darkThemeClass);
      localStorage.setItem('typestyles-theme', 'light');
    }
  }

  function toggleTheme() {
    setTheme(!root.classList.contains(darkThemeClass));
  }

  function setSidebar(open) {
    isOpen = open;
    if (!sidebarElement || !backdropElement || !menuIconElement) return;

    sidebarElement.classList.toggle(sidebarRootOpenClass, isOpen);
    backdropElement.classList.toggle(sidebarBackdropVisibleClass, isOpen);
    document.body.style.overflow = isOpen ? 'hidden' : '';
    menuIconElement.textContent = isOpen ? '✕' : '☰';
  }

  menuToggleElement?.addEventListener('click', () => setSidebar(!isOpen));
  backdropElement?.addEventListener('click', () => setSidebar(false));
  sidebarThemeToggleElement?.addEventListener('click', toggleTheme);
  mobileThemeToggleElement?.addEventListener('click', toggleTheme);

  document.addEventListener('click', async (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;
    const button = target.closest('[data-codeblock-copy]');
    if (!(button instanceof HTMLButtonElement)) return;

    const rootEl = button.closest('[data-codeblock]');
    if (!rootEl) return;
    const codeEl = rootEl.querySelector('pre code');
    if (!codeEl) return;

    const text = codeEl.textContent ?? '';
    try {
      await navigator.clipboard.writeText(text);
      button.textContent = 'Copied';
      button.dataset.copied = 'true';
      setTimeout(() => {
        button.textContent = 'Copy';
        delete button.dataset.copied;
      }, 1200);
    } catch {
      button.textContent = 'Error';
      button.dataset.error = 'true';
      setTimeout(() => {
        button.textContent = 'Copy';
        delete button.dataset.error;
      }, 1200);
    }
  });
</script>
