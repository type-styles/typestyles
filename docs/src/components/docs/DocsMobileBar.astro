---
import { Search } from '@lucide/astro';
import { mobileBar } from '../../styles';
import DocsLogo from './DocsLogo.astro';
---

<div class={mobileBar.root}>
  <button class={mobileBar.menuBtn} id="mobile-menu-toggle" aria-label="Open menu" type="button">
    <span id="mobile-menu-icon">☰</span>
  </button>
  <div class={mobileBar.logoWrap}>
    <DocsLogo className={mobileBar.logo} accentClassName={mobileBar.logoAccent} />
  </div>
  <div class={mobileBar.actions}>
    <button
      type="button"
      class={mobileBar.menuBtn}
      data-docs-search-trigger
      aria-label="Open search (Command+K)"
      aria-keyshortcuts="Meta+K Control+K"
    >
      <Search size={20} stroke-width={2} aria-hidden="true" />
    </button>
    <a
      href="https://github.com/typestyles/typestyles"
      class={mobileBar.iconLink}
      aria-label="typestyles on GitHub"
      target="_blank"
      rel="noopener noreferrer"
    >
      GH
    </a>
  </div>
</div>
