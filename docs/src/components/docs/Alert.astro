---
// @ts-nocheck
import { alert } from '@examples/design-system';

export type AlertVariant = 'info' | 'success' | 'warning' | 'danger' | 'tip';
export type AlertAppearance = 'subtle' | 'solid';

interface Props {
  variant: AlertVariant;
  appearance?: AlertAppearance;
  title?: string;
  actionLabel?: string;
  actionHref?: string;
}

const {
  variant,
  appearance = 'subtle',
  title,
  actionLabel,
  actionHref,
} = Astro.props as Props;

const a = alert({
  tone: variant,
  appearance,
  contentGap: title ? 'spaced' : 'flush',
});

const hasIcon = Astro.slots.has('icon');
---

<div class:list={[a.root]} data-alert data-alert-variant={variant} data-alert-appearance={appearance}>
  {
    hasIcon ? (
      <div class={a.icon} data-alert-icon>
        <slot name="icon" />
      </div>
    ) : null
  }
  <div class={a.body}>
    {title ? <p class={a.title}>{title}</p> : null}
    <div class={a.content} data-alert-content>
      <slot />
    </div>
    {
      actionLabel && actionHref ? (
        <div class={a.action}>
          <a class={a.actionLink} href={actionHref} data-alert-action>
            {actionLabel}
          </a>
        </div>
      ) : null
    }
  </div>
</div>
