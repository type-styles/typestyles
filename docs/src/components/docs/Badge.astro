---
// @ts-nocheck
import { badge } from '@examples/design-system';

export type BadgeVariant = 'neutral' | 'accent' | 'success' | 'warning' | 'danger' | 'tip';

interface Props {
  variant?: BadgeVariant;
}

const { variant = 'neutral' } = Astro.props as Props;

const tone: Record<BadgeVariant, string> = {
  neutral: badge('neutral'),
  accent: badge('accent'),
  success: badge('success'),
  warning: badge('warning'),
  danger: badge('danger'),
  tip: badge('tip'),
};
---

<span class:list={[badge('root'), tone[variant]]}>
  <slot />
</span>
