---
// @ts-nocheck
import { Search } from '@lucide/astro';
import { sidebar } from '../../styles';
import { docNavigation } from '../../navigation';
import type { DocMeta } from '../../lib/docs';
import type { AppearanceBootstrap } from '../../lib/docsAppearanceRuntime';
import DocsLogo from './DocsLogo.astro';
import DocsAppearanceControls from './DocsAppearanceControls.astro';

type Props = {
  docsBySlug: Record<string, DocMeta>;
  currentSlug: string;
  appearanceBootstrap: AppearanceBootstrap;
};

const { docsBySlug, currentSlug, appearanceBootstrap } = Astro.props;
---

<div className={sidebar.backdrop} id="sidebar-backdrop" aria-hidden="true"></div>
<aside className={sidebar.root} id="docs-sidebar">
  <div className={sidebar.header}>
    <DocsLogo className={sidebar.logo} accentClassName={sidebar.logoAccent} />
  </div>
  <div className={sidebar.searchWrapper}>
    <span className={sidebar.searchIcon} aria-hidden="true">
      <Search size={16} stroke-width={2} />
    </span>
    <button
      type="button"
      id="docs-search-trigger"
      className={sidebar.searchTrigger}
      aria-label="Open search (Command+K)"
      aria-keyshortcuts="Meta+K Control+K"
    >
      Search docs…
    </button>
    <span className={sidebar.searchKbd} aria-hidden="true">⌘K</span>
  </div>
  <nav
    className={sidebar.nav}
    data-docs-nav
    data-link-class={sidebar.link}
    data-link-active-class={sidebar.linkActive}
  >
    {
      docNavigation.categories.map((category) => (
        <div className={sidebar.section}>
          <div className={sidebar.sectionTitle}>{category.title}</div>
          {category.items.map((item) => {
          const href = item.href ?? (item.slug ? `/docs/${item.slug}` : undefined);
          if (!href) return null;
          const title = item.slug ? (docsBySlug[item.slug]?.title ?? item.title) : item.title;
            const activeClass =
              href === currentSlug
                ? `${sidebar.link} ${sidebar.linkActive}`
                : sidebar.link;
            return (
              <a href={href} className={activeClass}>
                {title}
              </a>
            );
          })}
        </div>
      ))
    }
  </nav>
  <DocsAppearanceControls appearanceBootstrap={appearanceBootstrap} />
</aside>

<script>
  function currentDocsSlugFromPath(): string {
    const path = window.location.pathname.replace(/\/$/, '');
    if (path === '/docs' || path === '') return '';
    return path;
  }

  function syncDocsNavActive(): void {
    const nav = document.querySelector<HTMLElement>('[data-docs-nav]');
    if (!nav) return;
    const linkBase = nav.dataset.linkClass;
    const linkActive = nav.dataset.linkActiveClass;
    if (!linkBase || !linkActive) return;
    const slug = currentDocsSlugFromPath();
    nav.querySelectorAll<HTMLAnchorElement>('a[href^="/docs/"]').forEach((a) => {
      const href = (a.getAttribute('href') ?? '').replace(/\/$/, '');
      const isActive = href === slug && slug !== '';
      a.className = isActive ? `${linkBase} ${linkActive}` : linkBase;
      if (isActive) a.setAttribute('aria-current', 'page');
      else a.removeAttribute('aria-current');
    });
  }

  document.addEventListener('astro:page-load', syncDocsNavActive);
  syncDocsNavActive();
</script>
