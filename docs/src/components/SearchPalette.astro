---
import { Search } from '@lucide/astro';
import { commandPalette } from '@examples/design-system';

const cp = commandPalette();
const cpOpen = commandPalette({ open: true });
const searchSlotClasses = JSON.stringify({ closed: cp, open: cpOpen });
---

<div id="docs-search-palette-root" class={cp.root} aria-hidden="true">
  <div id="docs-search-palette-backdrop" class={cp.backdrop} aria-hidden="true"></div>
  <div
    id="docs-search-palette-dialog"
    role="dialog"
    aria-label="Search documentation"
    class={cp.dialog}
  >
    <script type="application/json" id="docs-search-slot-classes" set:html={searchSlotClasses} />
    <div class={cp.inputRow}>
      <span class={cp.inputIcon} aria-hidden="true">
        <Search size={20} stroke-width={2} />
      </span>
      <input
        id="docs-palette-input"
        type="search"
        class={cp.input}
        placeholder="Search the docs…"
        autocomplete="off"
        aria-expanded="false"
        aria-controls="docs-palette-results"
        aria-autocomplete="list"
        role="combobox"
      />
    </div>
    <ul
      id="docs-palette-results"
      class={cp.results}
      role="listbox"
      aria-label="Search results"
    >
    </ul>
  </div>
</div>

<script>
  import { initDocsSearch } from '../scripts/docsSearch';

  function bootDocsSearch(): void {
    initDocsSearch();
  }

  document.addEventListener('astro:page-load', bootDocsSearch);
  bootDocsSearch();
</script>
