---
// @ts-nocheck
import { toc } from '../styles';
import type { DocHeading } from '../lib/docs';
import TocNav from './TocNav.astro';

interface Props {
  headings: DocHeading[];
}

const { headings } = Astro.props as Props;
const labelId = 'docs-page-toc-title';
const detailsId = 'docs-page-toc';
---

<div class={toc.root}>
  <details class={toc.details} id={detailsId}>
    <summary class={toc.summary}>On this page</summary>
    <div class={toc.panel}>
      <TocNav headings={headings} labelledBy={labelId} />
    </div>
  </details>
</div>
<script is:inline define:vars={{ detailsId }}>
  (function () {
    var mq = window.matchMedia('(min-width: 1024px)');
    function sync() {
      var el = document.getElementById(detailsId);
      if (!(el instanceof HTMLDetailsElement)) return;
      if (mq.matches) el.setAttribute('open', '');
      else el.removeAttribute('open');
    }
    mq.addEventListener('change', sync);
    document.addEventListener('astro:page-load', sync);
    sync();
  })();
</script>
