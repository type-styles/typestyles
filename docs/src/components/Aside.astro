---
// @ts-nocheck
/**
 * Starlight-style callout types → design-system `alert` variants.
 */
import Alert from './Alert.astro';

export type AsideType = 'note' | 'tip' | 'caution' | 'danger';

interface Props {
  type?: AsideType;
  title?: string;
  appearance?: 'subtle' | 'solid';
}

const { type = 'note', title, appearance = 'subtle' } = Astro.props as Props;

const variantMap: Record<AsideType, 'info' | 'tip' | 'warning' | 'danger'> = {
  note: 'info',
  tip: 'tip',
  caution: 'warning',
  danger: 'danger',
};

const defaultTitle: Record<AsideType, string> = {
  note: 'Note',
  tip: 'Tip',
  caution: 'Caution',
  danger: 'Danger',
};

const resolvedTitle = title ?? defaultTitle[type];
const variant = variantMap[type];
---

<Alert variant={variant} appearance={appearance} title={resolvedTitle}>
  <slot />
</Alert>
