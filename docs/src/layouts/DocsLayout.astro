---
// @ts-nocheck
import { layout, sidebar } from '../styles';
import {
  designPaletteList,
  docsAppearanceClassesToClear,
  getDocsAppearanceClass,
  type DesignPaletteId,
} from '../tokens';
import type { DocHeading } from '../lib/docs';
import Head from '../components/Head.astro';
import SkipLink from '../components/SkipLink.astro';
import SiteHeader from '../components/SiteHeader.astro';
import Sidebar from '../components/Sidebar.astro';
import CodeBlockCopy from '../components/CodeBlockCopy.astro';
import MobileSidebar from '../components/MobileSidebar.astro';
import Toc from '../components/Toc.astro';
import SearchPalette from '../components/SearchPalette.astro';
import { codeHljsScope } from '@examples/design-system';

type Props = {
  title?: string;
  currentSlug?: string;
  docsBySlug: Record<string, import('../lib/docs').DocMeta>;
  tocHeadings?: DocHeading[];
  /** Hide the persistent docs sidebar on large screens (e.g. homepage has top nav already). */
  hideDesktopSidebar?: boolean;
  /** Wider main column for marketing layouts. */
  mainVariant?: 'doc' | 'landing';
};

const {
  title = 'typestyles - CSS-in-TypeScript',
  currentSlug = '',
  docsBySlug,
  tocHeadings = [],
  hideDesktopSidebar = false,
  mainVariant = 'doc',
} = Astro.props;
const sidebarRootOpenClass = sidebar.rootOpen;
const sidebarBackdropVisibleClass = sidebar.backdropVisible;
const hasToc = tocHeadings.length > 0;

/** Vite/Astro `BASE_URL` ends with `/` when set. */
const typestylesCssHref = `${import.meta.env.BASE_URL}typestyles.css`;

const appearanceMap = Object.fromEntries(
  designPaletteList.map(({ id }) => [
    id,
    getDocsAppearanceClass(id, 'light'),
  ])
) as Record<DesignPaletteId, { className: string; dataMode: 'light' | 'dark' | undefined }>;

const appearanceBootstrap = {
  clear: docsAppearanceClassesToClear.filter(Boolean),
  map: appearanceMap,
};

---

<html lang="en">
  <head>
    <Head
      title={title}
      appearanceBootstrap={appearanceBootstrap}
      typestylesCssHref={typestylesCssHref}
    />
  </head>
  <body>
    <div transition:persist="docs-skip">
      <SkipLink />
    </div>
    <div transition:persist="docs-site-header">
      <SiteHeader appearanceBootstrap={appearanceBootstrap} />
    </div>

    <div class:list={[layout.root, codeHljsScope.root]}>
      <div
        data-docs-sidebar-shell
        class:list={[layout.sidebarShell, hideDesktopSidebar && layout.sidebarShellHiddenDesktop]}
        transition:persist="docs-sidebar-shell"
      >
        <Sidebar docsBySlug={docsBySlug} currentSlug={currentSlug} />
      </div>

      <div className={layout.content} transition:name="docs-main">
        {
          hasToc ? (
            <div class:list={[layout.docPageWrap, layout.docPageWrapWithToc]}>
              <aside class={layout.tocAside} aria-label="On this page">
                <Toc headings={tocHeadings} />
              </aside>
              <div class={layout.mainColumn}>
                <main
                  id="main-content"
                  tabindex="-1"
                  class:list={[mainVariant === 'landing' ? layout.mainLanding : layout.main]}
                >
                  <slot />
                </main>
              </div>
            </div>
          ) : (
            <main
              id="main-content"
              tabindex="-1"
              class:list={[mainVariant === 'landing' ? layout.mainLanding : layout.main]}
            >
              <slot />
            </main>
          )
        }
      </div>
    </div>

    <CodeBlockCopy />
    <MobileSidebar
      sidebarRootOpenClass={sidebarRootOpenClass}
      sidebarBackdropVisibleClass={sidebarBackdropVisibleClass}
    />

    <SearchPalette />

    <script>
      import { attachDocInstallTabs } from '../scripts/docInstallTabs';
      attachDocInstallTabs();
    </script>

    <script define:vars={{ sidebarHiddenDesktopClass: layout.sidebarShellHiddenDesktop }}>
      /**
       * `transition:persist` keeps the sidebar shell across client navigations, so classes from the
       * first visited page (e.g. homepage hide-desktop) would stick. Re-sync after each navigation.
       */
      function syncSidebarShellDesktopVisibility() {
        const shell = document.querySelector('[data-docs-sidebar-shell]');
        if (!shell || !sidebarHiddenDesktopClass) return;
        const path = window.location.pathname.replace(/\/$/, '') || '/';
        const hideDesktopSidebar = path === '/';
        shell.classList.toggle(sidebarHiddenDesktopClass, hideDesktopSidebar);
      }

      document.addEventListener('astro:page-load', syncSidebarShellDesktopVisibility);
      syncSidebarShellDesktopVisibility();
    </script>
  </body>
</html>
