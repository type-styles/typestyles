---
// @ts-nocheck
import { layout, sidebar } from '../styles';
import { darkTheme } from '../tokens';
import type { DocHeading } from '../lib/docs';
import DocsHead from '../components/docs/DocsHead.astro';
import DocsSkipLink from '../components/docs/DocsSkipLink.astro';
import DocsMobileBar from '../components/docs/DocsMobileBar.astro';
import DocsSidebar from '../components/docs/DocsSidebar.astro';
import DocsCodeBlockCopy from '../components/docs/DocsCodeBlockCopy.astro';
import DocsThemeToggle from '../components/docs/DocsThemeToggle.astro';
import DocsMobileSidebar from '../components/docs/DocsMobileSidebar.astro';
import DocsToc from '../components/docs/DocsToc.astro';
import { codeHljsScope } from '@examples/design-system';

type Props = {
  title?: string;
  currentSlug?: string;
  docsBySlug: Record<string, import('../lib/docs').DocMeta>;
  tocHeadings?: DocHeading[];
};

const { title = 'typestyles - CSS-in-TypeScript', currentSlug = '', docsBySlug, tocHeadings = [] } =
  Astro.props;
const sidebarRootOpenClass = sidebar('rootOpen');
const sidebarBackdropVisibleClass = sidebar('backdropVisible');
const hasToc = tocHeadings.length > 0;

/** Vite/Astro `BASE_URL` ends with `/` when set. */
const typestylesCssHref = `${import.meta.env.BASE_URL}typestyles.css`;
---

<html lang="en">
  <head>
    <DocsHead title={title} darkThemeClass={darkTheme} />
  </head>
  <body>
    <DocsSkipLink />
    <DocsMobileBar />

    <div class:list={[layout('root'), codeHljsScope('root')]}>
      <DocsSidebar docsBySlug={docsBySlug} currentSlug={currentSlug} />

      <div className={layout('content')}>
        {
          hasToc ? (
            <div class:list={[layout('docPageWrap'), layout('docPageWrapWithToc')]}>
              <aside class={layout('tocAside')} aria-label="On this page">
                <DocsToc headings={tocHeadings} />
              </aside>
              <div class={layout('mainColumn')}>
                <main id="main-content" tabindex="-1" class={layout('main')}>
                  <slot />
                </main>
              </div>
            </div>
          ) : (
            <main id="main-content" tabindex="-1" class={layout('main')}>
              <slot />
            </main>
          )
        }
      </div>
    </div>

    <DocsCodeBlockCopy />
    <DocsThemeToggle darkThemeClass={darkTheme} />
    <DocsMobileSidebar
      sidebarRootOpenClass={sidebarRootOpenClass}
      sidebarBackdropVisibleClass={sidebarBackdropVisibleClass}
    />
    {import.meta.env.PROD && <link rel="stylesheet" href={typestylesCssHref} />}
  </body>
</html>
