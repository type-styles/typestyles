---
import { home } from '../styles';
import DocsLayout from '../layouts/DocsLayout.astro';
import Code from '../components/docs/Code.astro';
import { getAllDocs } from '../lib/docs';

const docs = await getAllDocs();
const docsBySlug = Object.fromEntries(docs.map((doc) => [doc.slug, { slug: doc.slug, title: doc.title }]));

const themeTsSample = `const button = styles.component('button', {
  base: { border: '3px solid #000' },
  variants: {
    intent: {
      primary: { background: token.accent },
      ghost: { background: 'transparent' },
    },
  },
});`;
---

<DocsLayout docsBySlug={docsBySlug}>
  <div class={home.hero}>
    <h1 class={home.title}>
      CSS-in-TypeScript that
      <br />
      <span class={home.titleAccent}>embraces CSS</span>
    </h1>
    <p class={home.subtitle}>
      Design tokens, style variants, and keyframes — with full control over the CSS. No runtime
      overhead, no magic, just types.
    </p>
    <div class={home.actions}>
      <a href="/docs/getting-started" class={home.cta}>
        Get started
        <span aria-hidden="true">&rarr;</span>
      </a>
      <a
        href="https://github.com/typestyles/typestyles"
        class={home.ctaSecondary}
        target="_blank"
        rel="noopener noreferrer"
      >
        GitHub
      </a>
    </div>
    <div class={home.codeExampleWrap}>
      <Code code={themeTsSample} lang="typescript" headerLabel="theme.ts" />
    </div>
  </div>
</DocsLayout>
