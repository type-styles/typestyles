---
import DocsLayout from '../../layouts/DocsLayout.astro';
import { doc, docProseRoot } from '../../styles';
import { docNavigation } from '../../navigation';
import { getAllDocs } from '../../lib/docs';

const docs = await getAllDocs();
const docsBySlug = Object.fromEntries(docs.map((entry) => [entry.slug, entry]));
---

<DocsLayout docsBySlug={docsBySlug} currentSlug="">
  <div class={doc.root}>
    <h1 class={doc.title}>Documentation</h1>
    <p class={doc.description}>
      Welcome to the typestyles documentation. Choose a topic from the sidebar or start with{' '}
      <a href="/docs/getting-started">Getting Started</a>.
    </p>

    <div class:list={[docProseRoot, doc.content]}>
      {
        docNavigation.categories.map((category) => (
          <div>
            <h2>{category.title}</h2>
            <ul>
              {category.items.map((item) => {
                const entry = docsBySlug[item.slug];
                if (!entry) return null;
                return (
                  <li>
                    <a href={`/docs/${item.slug}`}>{entry.title}</a>
                  </li>
                );
              })}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</DocsLayout>
