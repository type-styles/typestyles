---
// @ts-nocheck
import DocsLayout from '../../../layouts/DocsLayout.astro';
import Alert from '../../../components/docs/Alert.astro';
import Aside from '../../../components/docs/Aside.astro';
import Badge from '../../../components/docs/Badge.astro';
import Card from '../../../components/docs/Card.astro';
import CardGrid from '../../../components/docs/CardGrid.astro';
import Code from '../../../components/docs/Code.astro';
import FileTree from '../../../components/docs/FileTree.astro';
import LinkCard from '../../../components/docs/LinkCard.astro';
import Steps from '../../../components/docs/Steps.astro';
import { doc, docProseRoot } from '../../../styles';
import { fileTree as fileTreeStyles, linkButton } from '@examples/design-system';
import { getAllDocs } from '../../../lib/docs';

const docs = await getAllDocs();
const docsBySlug = Object.fromEntries(docs.map((entry) => [entry.slug, entry]));
---

<DocsLayout
  docsBySlug={docsBySlug}
  currentSlug="/docs/design-system/kitchen-sink"
  title="Astro Design System Kitchen Sink - typestyles documentation"
>
  <article class={doc.root}>
    <h1 class={doc.title}>Astro Design System Kitchen Sink</h1>
    <p class={doc.description}>
      A single page that renders all current Astro design-system components used in this docs site.
    </p>

    <div class:list={[docProseRoot, doc.content]}>
      <h2>Alert</h2>
      <Alert variant="info" title="Info">
        Informational callout with subtle appearance.
      </Alert>
      <Alert variant="tip" title="Tip" actionLabel="Read component docs" actionHref="/docs/component-library">
        Tip with optional action link.
      </Alert>
      <Alert variant="warning" appearance="solid" title="Warning">
        Solid warning surface for higher emphasis.
      </Alert>
      <Alert variant="danger" title="Danger">
        <span slot="icon" aria-hidden="true">!</span>
        Danger alert with icon slot content.
      </Alert>

      <h2>Aside</h2>
      <Aside type="note">Aside note variant.</Aside>
      <Aside type="tip">Aside tip variant.</Aside>
      <Aside type="caution">Aside caution variant.</Aside>
      <Aside type="danger">Aside danger variant.</Aside>

      <h2>Badge</h2>
      <p>
        <Badge>neutral</Badge>{' '}
        <Badge variant="accent">accent</Badge>{' '}
        <Badge variant="success">success</Badge>{' '}
        <Badge variant="warning">warning</Badge>{' '}
        <Badge variant="danger">danger</Badge>{' '}
        <Badge variant="tip">tip</Badge>
      </p>

      <h2>Card, CardGrid, and LinkCard</h2>
      <CardGrid>
        <Card title="Card title">Simple card body content.</Card>
        <LinkCard
          href="/docs/components"
          title="Components"
          description="Go to the component system guide."
          hint="Open guide ->"
        />
      </CardGrid>

      <h2>Steps</h2>
      <Steps>
        <li>
          <p>Install typestyles and the related packages.</p>
        </li>
        <li>
          <p>Import your component styles in your app entry.</p>
        </li>
        <li>
          <p>Compose components and theme tokens in pages.</p>
        </li>
      </Steps>

      <h2>FileTree</h2>
      <FileTree>
        <ul class={fileTreeStyles.list}>
          <li class={fileTreeStyles.item}>
            <div class:list={[fileTreeStyles.row, fileTreeStyles.folder]}>src/</div>
            <ul class={fileTreeStyles.listNested}>
              <li class={fileTreeStyles.item}>
                <div class:list={[fileTreeStyles.row, fileTreeStyles.file]}>components/</div>
              </li>
              <li class={fileTreeStyles.item}>
                <div class:list={[fileTreeStyles.row, fileTreeStyles.file]}>styles.ts</div>
              </li>
            </ul>
          </li>
        </ul>
      </FileTree>

      <h2>Code</h2>
      <Code
        lang="ts"
        code={`import { button } from '@examples/design-system';

const classes = button({ tone: 'primary', size: 'md' });
console.log(classes.root);`}
      />

      <h2>Link button classes</h2>
      <p>
        <a class:list={[linkButton.base, linkButton.primary]} href="/docs/getting-started">Primary</a>{' '}
        <a class:list={[linkButton.base, linkButton.secondary]} href="/docs/component-library">Secondary</a>{' '}
        <a class:list={[linkButton.base, linkButton.ghost]} href="/docs/tokens">Ghost</a>
      </p>
    </div>
  </article>
</DocsLayout>
