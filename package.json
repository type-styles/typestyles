{
  "name": "typestyles-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.11.1",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "dev": "turbo run dev",
    "build-runner": "pnpm --filter @typestyles/build-runner",
    "typestyles": "pnpm --filter typestyles",
    "props": "pnpm --filter @typestyles/props",
    "open-props": "pnpm --filter @typestyles/open-props",
    "vite": "pnpm --filter @typestyles/vite",
    "astro": "pnpm --filter @typestyles/astro",
    "rollup": "pnpm --filter @typestyles/rollup",
    "next": "pnpm --filter @typestyles/next",
    "migrate": "pnpm --filter @typestyles/migrate",
    "vite-app": "pnpm --filter typestyles-vite-example",
    "rollup-app": "pnpm --filter typestyles-rollup-example",
    "rolldown-app": "pnpm --filter typestyles-rolldown-example",
    "next-app": "pnpm --filter @examples/next",
    "design-system": "pnpm --filter @examples/design-system",
    "react-design-system": "pnpm --filter @examples/react-design-system",
    "typewind": "pnpm --filter @examples/typewind",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "changeset": "changeset",
    "version": "changeset version",
    "version:unstable": "node scripts/set-unstable-versions.js",
    "release": "turbo build && changeset publish",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,md}": "prettier --write"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.29.8",
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2.0.0",
    "typescript-eslint": "^8.54.0"
  }
}
